# ─── LLM Configuration ───────────────────────────────────────────────────────
# Set to "anthropic" or "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Primary model — used for jury agents, CAM generation
PRIMARY_MODEL=claude-sonnet-4-20250514
# Fast/cheap model — used for document classification
FAST_MODEL=claude-haiku-4-20250514

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://intellicredit:intellicredit@localhost:5432/intellicredit
POSTGRES_USER=intellicredit
POSTGRES_PASSWORD=intellicredit
POSTGRES_DB=intellicredit

# ─── Qdrant Vector DB ─────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─── Search (optional, for web intelligence) ──────────────────────────────────
SERP_API_KEY=your_serpapi_key_here

# ─── Databricks (optional, for feature store) ─────────────────────────────────
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your_databricks_token_here

# ─── App Settings ─────────────────────────────────────────────────────────────
DEMO_MODE=true          # When true, uses mock MCA/legal data for demo
SECRET_KEY=change-me-in-production-please
BACKEND_PORT=8000
FRONTEND_PORT=3000
